frag.o: frag.cpp frag.h def.h object.h s_fix.h coll.h sopwith.h plane.h   graphics.h soundsys.h tune.h sound.h bird.h flock.h smoke.h
	$(CPP) -c frag.cpp -o frag.o $(CXXFLAGS)

graphics.o: graphics.cpp graphics.h def.h title.h font.h sdl/graphics.h   sopwith.h object.h s_fix.h plane.h sprites.h sw_excep.h
	$(CPP) -c graphics.cpp -o graphics.o $(CXXFLAGS)

