# Project: Sopwith 3
# Makefile created by Dev-C++ 4.9.8.10

CPP  = g++.exe
CC   = gcc.exe
WINDRES = windres.exe
RES  = 
OBJ  = sopwith.o bird.o bomb.o bullet.o coll.o computer.o flock.o frag.o graphics.o ground.o init.o joystick.o keyboard.o main.o object.o ox.o plane.o player.o smoke.o sound.o sprites.o target.o timer.o message.o soundsys.o tune.o network.o remote.o sdl/event.o $(RES)
LINKOBJ  = sopwith.o bird.o bomb.o bullet.o coll.o computer.o flock.o frag.o graphics.o ground.o init.o joystick.o keyboard.o main.o object.o ox.o plane.o player.o smoke.o sound.o sprites.o target.o timer.o message.o soundsys.o tune.o network.o remote.o sdl/event.o $(RES)
LIBS =  -s -lSDLmain -lSDL -lNL_s -lwsock32 
INCS = 
CXXINCS = 
BIN  = ../sopwith3.exe
CXXFLAGS = $(CXXINCS)-Wold-style-cast -DSDL -DHAWKNL   -Wall -W
CFLAGS = $(INCS)  -Wall -W

.PHONY: all all-before all-after clean clean-custom

all: all-before ../sopwith3.exe all-after


clean: clean-custom
	rm -f $(OBJ) $(BIN)

$(BIN): $(OBJ)
	$(CPP) $(LINKOBJ) -o "..\sopwith3.exe" $(LIBS)

sopwith.o: sopwith.cpp sopwith.h def.h object.h s_fix.h plane.h init.h   resource.h sw_excep.h timer.h graphics.h sound.h keyboard.h joystick.h   network.h message.h soundsys.h tune.h ground.h player.h computer.h   remote.h target.h flock.h ox.h bomb.h frag.h smoke.h bullet.h
	$(CPP) -c sopwith.cpp -o sopwith.o $(CXXFLAGS)

bird.o: bird.cpp bird.h def.h object.h s_fix.h sopwith.h plane.h coll.h   ground.h graphics.h flock.h smoke.h
	$(CPP) -c bird.cpp -o bird.o $(CXXFLAGS)

bomb.o: bomb.cpp bomb.h def.h object.h s_fix.h plane.h sopwith.h coll.h   graphics.h sound.h soundsys.h tune.h bird.h flock.h smoke.h
	$(CPP) -c bomb.cpp -o bomb.o $(CXXFLAGS)

