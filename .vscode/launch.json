{
  // GDB must exist at miDebuggerPath. Install once in "MSYS2 MinGW 64-bit": pacman -S mingw-w64-x86_64-gdb
  // If MSYS2 is not under C:\msys64, use the second configuration and set user env MINGW64_GDB to your gdb.exe path.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug sopwith3 (gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/sopwith3/sopwith3.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/sopwith3",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "build: sopwith3 (MSYS2)"
    },
    {
      "name": "Debug sopwith3 (gdb, MINGW64_GDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/sopwith3/sopwith3.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/sopwith3",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "${env:MINGW64_GDB}",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "build: sopwith3 (MSYS2)"
    },
    {
      "name": "Debug sopwith3 allegro (gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/sopwith3/sopwith3-allegro.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/sopwith3",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "build: sopwith3 allegro (MSYS2)"
    },
    {
      "name": "Debug sopwith3 allegro (gdb, MINGW64_GDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/sopwith3/sopwith3-allegro.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/sopwith3",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "${env:MINGW64_GDB}",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "build: sopwith3 allegro (MSYS2)"
    }
  ]
}
